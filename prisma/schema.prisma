generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  role         Role         @default(USER)
  fullName     String?
  createdAt    DateTime     @default(now())
  weight       Decimal?     @db.Decimal(5, 2)
  height       Decimal?     @db.Decimal(4, 2)
  fitnessGoal  FitnessGoal?
}

enum Role {
  USER
  PERSONAL
  ADMIN
}

enum FitnessGoal {
  BUILD_MUSCLE
  LOSE_WEIGHT
  STAY_FIT
  INCREASE_STRENGTH
}
